# Syntropiq Control Plane — Environment Configuration
# Copy to .env.local and adjust for your deployment.

# Backend REST API base URL (used by Next.js API proxy routes, server-side only)
BACKEND_URL=http://localhost:8000

# WebSocket URL (used by browser-side WS connector, must be NEXT_PUBLIC_)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/governance
