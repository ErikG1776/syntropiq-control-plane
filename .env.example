# Syntropiq Control Plane — Environment Configuration
# Copy to .env.local and adjust for your deployment.

# Backend REST API base URL (used by Next.js API proxy routes, server-side only)
BACKEND_URL=http://localhost:8000

# NextAuth / Auth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret
AUTH_DEMO_USERS_JSON=[{"email":"viewer@local","password":"viewer","role":"viewer"},{"email":"operator@local","password":"operator","role":"operator"},{"email":"admin@local","password":"admin","role":"admin"}]
AUTH_DEV_BYPASS=true

# WebSocket URL (used by browser-side WS connector, must be NEXT_PUBLIC_)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/governance

# API key for authenticating requests to /api/* routes (optional).
# If not set, API routes are unauthenticated.
# Clients send via: X-Api-Key header or Authorization: Bearer <key>
# API_KEY=

# CORS: comma-separated list of allowed origins (default: * allows all)
# ALLOWED_ORIGINS=https://app.syntropiq.com,https://dashboard.syntropiq.com
